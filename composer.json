{
    "name": "mendesalexandre/php-nfse-nacional",
    "description": "SDK PHP framework-agnostic pra NFS-e Nacional (Padrão Brasileiro SEFIN) — emissão DPS, consulta, cancelamento e DANFSE (NT 008/2026). PHP 8.1+, PSR-3/PSR-18.",
    "keywords": ["nfse", "nfse-nacional", "sefin", "danfse", "fiscal", "brasil"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Alexandre Teixeira Mendes",
            "email": "alexandre.teixeira.mendes@hotmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-dom": "*",
        "ext-openssl": "*",
        "ext-libxml": "*",
        "ext-zlib": "*",
        "ext-mbstring": "*",
        "psr/http-client": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/http-factory": "^1.0",
        "psr/log": "^3.0",
        "guzzlehttp/guzzle": "^7.5",
        "tecnickcom/tcpdf": "^6.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PhpNfseNacional\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpNfseNacional\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
