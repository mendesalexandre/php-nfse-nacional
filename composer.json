{
    "name": "sinop/nfse-nacional",
    "description": "SDK PHP para NFS-e Nacional (Padrão Brasileiro) — emissão DPS, consulta, cancelamento e DANFSE (NT 008/2026). Framework-agnostic, PHP 8.1+, PSRs.",
    "keywords": ["nfse", "nfse-nacional", "sefin", "danfse", "cartorio", "sinop"],
    "license": "proprietary",
    "type": "library",
    "authors": [
        {
            "name": "Cartório SINOP",
            "email": "contato@1oficiosinop.com.br"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-dom": "*",
        "ext-openssl": "*",
        "ext-libxml": "*",
        "ext-zlib": "*",
        "ext-mbstring": "*",
        "psr/http-client": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/http-factory": "^1.0",
        "psr/log": "^3.0",
        "guzzlehttp/guzzle": "^7.5",
        "tecnickcom/tcpdf": "^6.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Sinop\\NfseNacional\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sinop\\NfseNacional\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "phpstan": "phpstan analyse src --level=8",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
